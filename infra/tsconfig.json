{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": false,
    "isolatedModules": false,
    "esModuleInterop": true
  },
  "include": ["bin/**/*.ts", "lib/**/*.ts"]
}
